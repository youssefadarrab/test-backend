# Dev defaults, copy to .env. These are NOT production secrets.
ENV=local

# Postgres
DATABASE_URL=postgresql+psycopg2://primmo:primmo@db:5432/primmo

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Auth (HS256 dev secret; prod would use RS256 + JWKS)
JWT_SECRET=dev-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Shared secret for the partner webhook signature (X-Partner-Signature)
PARTNER_HMAC_SECRET=dev-partner-secret

# Pipeline / recovery tuning
STEP_MAX_ATTEMPTS=5

# Where uploaded bytes are stored (the files are never read, mocks only)
STORAGE_DIR=/data/storage
